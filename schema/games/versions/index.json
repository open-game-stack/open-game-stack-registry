{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "@context": {
      "type": "string"
    },
    "@type": {
      "type": "string",
      "const": "SoftwareApplication"
    },
    "@id": {
      "type": "string",
      "format": "uri"
    },
    "name": {
      "type": "string"
    },
    "version": {
      "type": "string"
    },
    "datePublished": {
      "type": "string"
    },
    "releaseNotes": {
      "type": "string"
    },
    "isPartOf": {
      "type": "object",
      "properties": {
        "@id": {
          "type": "string",
          "format": "uri"
        },
        "@type": {
          "type": "string",
          "const": "SoftwareApplication"
        },
        "name": {
          "type": "string"
        }
      },
      "required": [
        "@id",
        "@type"
      ],
      "additionalProperties": false
    },
    "associatedMedia": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "@type": {
            "type": "string",
            "const": "MediaObject"
          },
          "name": {
            "type": "string"
          },
          "contentSize": {
            "type": "integer",
            "minimum": 0,
            "maximum": 9007199254740991
          },
          "sha256": {
            "type": "string",
            "pattern": "^[a-f0-9]{64}$"
          },
          "contentUrl": {
            "type": "string",
            "format": "uri"
          },
          "encodingFormat": {
            "type": "string"
          },
          "license": {
            "type": "string",
            "format": "uri"
          },
          "operatingSystem": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "processorRequirements": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "required": [
          "@type",
          "name",
          "contentSize",
          "sha256",
          "contentUrl",
          "encodingFormat",
          "license"
        ],
        "additionalProperties": false
      }
    }
  },
  "required": [
    "@context",
    "@type",
    "@id",
    "name",
    "version",
    "datePublished",
    "releaseNotes",
    "isPartOf",
    "associatedMedia"
  ],
  "additionalProperties": false,
  "$id": "https://kmturley.github.io/static-api-json-schema/schema/games/versions"
}