{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "@context": {
      "type": "string"
    },
    "@type": {
      "type": "string",
      "const": "SoftwareApplication"
    },
    "@id": {
      "type": "string",
      "format": "uri"
    },
    "name": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "applicationCategory": {
      "type": "string"
    },
    "keywords": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "publisher": {
      "type": "object",
      "properties": {
        "@id": {
          "type": "string",
          "format": "uri"
        },
        "@type": {
          "type": "string",
          "const": "Organization"
        },
        "name": {
          "type": "string"
        }
      },
      "required": [
        "@id",
        "@type"
      ],
      "additionalProperties": false
    },
    "url": {
      "type": "string",
      "format": "uri"
    },
    "image": {
      "anyOf": [
        {
          "type": "string",
          "format": "uri"
        },
        {
          "type": "null"
        }
      ]
    },
    "versions": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "@id": {
            "type": "string",
            "format": "uri"
          },
          "@type": {
            "type": "string",
            "const": "SoftwareApplication"
          },
          "name": {
            "type": "string"
          }
        },
        "required": [
          "@id",
          "@type"
        ],
        "additionalProperties": false
      }
    },
    "latestVersion": {
      "type": "object",
      "properties": {
        "@id": {
          "type": "string",
          "format": "uri"
        },
        "@type": {
          "type": "string",
          "const": "SoftwareApplication"
        },
        "name": {
          "type": "string"
        }
      },
      "required": [
        "@id",
        "@type"
      ],
      "additionalProperties": false
    }
  },
  "required": [
    "@context",
    "@type",
    "@id",
    "name",
    "description",
    "applicationCategory",
    "publisher",
    "url"
  ],
  "additionalProperties": false,
  "$id": "https://open-game-stack.github.io/open-game-stack-registry/schema/games"
}